# MusicWorks™ — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.
#
# This file documents every provider MusicWorks knows about (see
# execution/provider_registry.py, the single source of truth). Nothing here
# is required for the app to run — everything falls back to mock output or
# a manual-production brief when a key is missing.

# ── AI Writing ──────────────────────────────────────────────────────────────

# Required for real (non-mock) text generation: blog, email, press release,
# captions, church outreach. LIVE TODAY.
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Research ─────────────────────────────────────────────────────────────────

# Optional — trend analysis, scripture context, fact-checking. Available for
# future integration; no worker calls this yet.
# Get one at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ── Video Generation ───────────────────────────────────────────────────────

# Optional — Hero Worker #1 (Cinematic Video): official music videos,
# trailers, visualizers, worship backgrounds. LIVE TODAY. Without this,
# MusicWorks produces a storyboard + prompt brief for manual production.
# Get one at: https://ai.google.dev
GOOGLE_VEO_API_KEY=

# Optional — Hero Worker #2 (Artist Presence): Shorts, Reels, TikTok,
# countdowns, artist intros, devotionals. Available for future integration;
# no worker calls this yet (manual-production brief is produced instead).
# Get one at: https://www.hedra.com
HEDRA_API_KEY=

# Optional — multi-language AI avatar/presenter video. Available for future
# integration; no worker calls this yet.
# Get one at: https://heygen.com
HEYGEN_API_KEY=

# ── Image Generation ───────────────────────────────────────────────────────

# Optional — hero artwork, album covers, character art. Available for future
# integration; no worker calls this yet.
# Get one at: https://leonardo.ai
LEONARDO_API_KEY=

# Optional — Google Imagen: photorealistic imagery, lifestyle/marketing
# shots. Available for future integration; no worker calls this yet.
# Get one at: https://ai.google.dev
GOOGLE_AI_API_KEY=

# Optional — design briefs for quote cards, thumbnails, story slides,
# countdown graphics. Available for future integration; without this,
# MusicWorks produces step-by-step Canva instructions instead of calling
# the API. (Legacy alias: CANVA_API_TOKEN, still read as a fallback.)
# Get one at: https://www.canva.com/developers
CANVA_API_KEY=

# Optional — your Canva Kingdom Words template ID (once you create one)
CANVA_KINGDOM_WORDS_TEMPLATE_ID=

# ── Video Editing (subscription-only — no API key checked yet) ─────────────

# Reserved for future API integration. Today, mark the subscription active
# in the Media Toolbox > Provider Library instead of setting a key here.
CAPCUT_API_KEY=
VIZARD_API_KEY=
PICTORY_API_KEY=

# ── Voice ─────────────────────────────────────────────────────────────────

# Optional — voice narration, spoken scripture, devotional audio. Available
# for future integration; no worker calls this yet.
# Get one at: https://elevenlabs.io
ELEVENLABS_API_KEY=

# ── Publishing (enables future automated publishing — optional) ────────────
# MusicWorks prepares content for manual publishing today. None of these are
# required for the core Media Factory to operate.

YOUTUBE_API_KEY=
INSTAGRAM_API_KEY=
FACEBOOK_API_KEY=
TIKTOK_API_KEY=
X_API_KEY=
THREADS_API_KEY=
RUMBLE_API_KEY=

# ── Newsletter (optional) ───────────────────────────────────────────────────

MAILCHIMP_API_KEY=
BEEHIIV_API_KEY=

# ── Website (optional, not an API key — just your artist site URL) ─────────

WEBSITE_URL=

# DistroKid requires no key — release metadata (ISRC, UPC, streaming links)
# is entered directly in the app; there is no distribution automation.
