# MindSpark MusicWorks™ V2 — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required — your Anthropic API key
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Canva API token (V2.5+)
# Without this, thumbnail agent generates Canva instructions instead of calling the API.
# Get one at: https://www.canva.com/developers
CANVA_API_TOKEN=

# Optional — your Canva Kingdom Words template ID (once you create it)
CANVA_KINGDOM_WORDS_TEMPLATE_ID=
